<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad="OnRibbonLoad">
  <ribbon>
    <tabs>
      <tab id="liveWebTab" label="Live Web">
        <group id="liveWebFrameGroup" label="Frame">
          <button id="btnCreate"
                  label="Fenster erstellen"
                  size="large"
                  imageMso="ShapeRectangle"
                  onAction="OnCreateFrame"
                  screentip="Live-Web-Fenster erstellen"
                  supertip="F&#252;gt einen neuen Live Web Frame ein und &#246;ffnet die Konfiguration (URL oder HTML-Datei)." />
          <button id="btnOptions"
                  label="Optionen"
                  size="large"
                  imageMso="TablePropertiesDialog"
                  onAction="OnOptions"
                  getEnabled="OnGetRegionSelected"
                  screentip="Link &amp; Optionen"
                  supertip="Bearbeitet Adresse und Optionen des markierten Frames (Zoom, Interaktiv, Stummschalten, Auto-Neuladen, Einbetten)." />
          <button id="btnRemove"
                  label="Fenster entfernen"
                  size="large"
                  imageMso="Delete"
                  onAction="OnRemoveFrame"
                  getEnabled="OnGetRegionSelected"
                  screentip="Frame entfernen"
                  supertip="Entfernt die Web-Zuordnung von der markierten Form." />
        </group>
        <group id="liveWebToolsGroup" label="Werkzeuge">
          <button id="btnReload"
                  label="Neu laden"
                  size="large"
                  imageMso="Refresh"
                  onAction="OnReload"
                  screentip="Neu laden"
                  supertip="L&#228;dt die Web-Inhalte der aktuellen Folie neu." />
        </group>
        <group id="liveWebHelpGroup" label="Hilfe">
          <button id="btnUpdate"
                  label="Update"
                  size="large"
                  imageMso="SynchronizeList"
                  onAction="OnCheckUpdate"
                  screentip="Nach Updates suchen"
                  supertip="Pr&#252;ft online, ob eine neue Version verf&#252;gbar ist, und installiert sie." />
          <button id="btnHelp"
                  label="Anleitung"
                  size="large"
                  imageMso="Help"
                  onAction="OnShowHelp"
                  screentip="Anleitung &#246;ffnen"
                  supertip="Zeigt eine Kurzanleitung zur Verwendung des Add-ins." />
          <button id="btnAbout"
                  label="Info"
                  size="large"
                  imageMso="Info"
                  onAction="OnShowAbout"
                  screentip="&#220;ber dieses Add-in"
                  supertip="Copyright, Version und Lizenzinformationen." />
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
